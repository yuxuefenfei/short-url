{
  "project": {
    "name": "short-url",
    "version": "1.1.0",
    "lastUpdated": "2026-03-18"
  },
  "responseContract": {
    "wrapper": "ApiResponse<T>",
    "pageWrapper": "ApiResponse<PageResult<T>>",
    "successCode": 200,
    "successMessage": "操作成功",
    "responseFields": ["code", "message", "data", "timestamp", "requestId"],
    "pageFields": ["list", "total", "page", "size", "totalPages"],
    "frontendRule": "先判断 response.code === 200，再读取 response.data"
  },
  "publicApis": [
    "POST /api/shorten",
    "GET /api/stats/{shortKey}",
    "GET /{shortKey}",
    "POST /api/client-errors"
  ],
  "authApis": [
    "POST /api/auth/login",
    "POST /api/auth/register",
    "GET /api/auth/check-username",
    "POST /api/auth/refresh-token",
    "POST /api/auth/logout",
    "GET /api/auth/validate-token",
    "GET /api/auth/current-user"
  ],
  "adminApis": [
    "GET /api/admin/users",
    "POST /api/admin/users",
    "GET /api/admin/users/{userId}",
    "PUT /api/admin/users/{userId}",
    "PUT /api/admin/users/{userId}/status",
    "POST /api/admin/users/{userId}/reset-password",
    "DELETE /api/admin/users/{userId}",
    "GET /api/admin/system-stats",
    "GET /api/admin/urls",
    "GET /api/admin/urls/{id}",
    "PUT /api/admin/urls/{id}",
    "PUT /api/admin/urls/{id}/status",
    "DELETE /api/admin/urls/{id}",
    "PUT /api/admin/urls/batch-status",
    "DELETE /api/admin/urls/batch",
    "GET /api/admin/urls/{shortKey}/stats",
    "GET /api/admin/operation-logs",
    "GET /api/admin/operation-logs/stats",
    "GET /api/admin/dashboard/overview"
  ],
  "databaseTables": [
    "short_url_mapping",
    "url_access_log",
    "user",
    "user_operation_log"
  ],
  "commands": {
    "backendRun": "mvn spring-boot:run",
    "backendTest": "mvn test",
    "backendBuild": "mvn -DskipTests package",
    "frontendInstall": "npm install",
    "frontendDev": "npm run dev",
    "frontendBuild": "npm run build"
  },
  "docs": {
    "readme": "README.md",
    "apiSpec": "docs/api/api-spec.yaml",
    "responseFormat": "docs/api/response-format.md",
    "dataDictionary": "docs/database/data-dictionary.md",
    "schemaSql": "docs/database/schema.sql"
  }
}
